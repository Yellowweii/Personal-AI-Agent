# 复制本文件为 .env.local 后填入真实值
# cp .env.example .env.local

# =============================================================================
# 当前生效配置
# =============================================================================

# --- Text / Image / 意图识别（OpenAI 兼容 /v1）---
# 示例供应商：Agnes / SiliconFlow 等
LLM_API_BASE_URL=https://api.example.com
LLM_API_KEY=sk-your-llm-api-key
LLM_TEXT_MODEL=your-text-model
LLM_IMAGE2TEXT_MODEL=your-vision-model
LLM_TEXT2IMAGE_MODEL=your-text-to-image-model
LLM_IMAGE2IMAGE_MODEL=your-image-to-image-model
LLM_TEXT2VIDEO_MODEL=your-text-to-video-model
LLM_IMAGE2VIDEO_MODEL=your-image-to-video-model

# --- STT 语音转文字 ---
# 可与 LLM 使用不同供应商（例如 SiliconFlow）
STT_API_BASE_URL=https://api.siliconflow.cn
STT_API_KEY=sk-your-stt-api-key
LLM_STT_MODEL=TeleAI/TeleSpeechASR
DEFAULT_STT_MODEL=FunAudioLLM/SenseVoiceSmall

# --- TTS 文字转语音（Azure Speech）---
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_REGION=eastasia
AZURE_TTS_VOICE=zh-CN-XiaoxiaoNeural

# --- 图片上传（七牛云 OSS）---
QINIU_ACCESS_KEY=your-qiniu-access-key
QINIU_SECRET_KEY=your-qiniu-secret-key
QINIU_CDN_BASE_URL=https://cdn.example.com
QINIU_UPLOAD_HOST=https://up-z2.qiniup.com


# =============================================================================
# 站点配置（可选）
# =============================================================================
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
